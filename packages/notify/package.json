{
  "name": "reusables-notify",
  "version": "0.1.2",
  "description": "A composable toast notification package for React.",
  "license": "MIT",
  "homepage": "https://reusables.vercel.app/docs/components/notify",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whyte25/reusables.git",
    "directory": "packages/notify"
  },
  "bugs": {
    "url": "https://github.com/whyte25/reusables/issues"
  },
  "keywords": [
    "toast",
    "notification",
    "react",
    "nextjs",
    "shadcn",
    "reusables"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  }
}
