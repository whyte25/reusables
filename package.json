    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.59.3",
    "typescript": "^6.0.3",
    "unist-builder": "4.0.0",
    "unist-util-visit": "^5.0.0"
  }
