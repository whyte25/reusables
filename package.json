{
  "name": "reusables",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:notify": "bun run build:notify && changeset publish",
    "build:notify": "bun run --cwd packages/notify build",
    "build:registry": "shadcn build && bun run ./scripts/build-registry.mts && prettier --write registry.json __registry__/index.tsx 'registry/**/*.{ts,tsx}' 'public/r/**/*.json'",
    "build": "next build && bun run build:registry",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "publisher": "fas",
  "licence": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@shikijs/transformers": "^1.26.1",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@types/js-cookie": "^3.0.6",
    "@types/mdx": "^2.0.13",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vercel/analytics": "^1.4.1",
    "@vercel/speed-insights": "^1.1.0",
    "@wojtekmaj/react-hooks": "^1.22.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.8.11",
    "fumadocs-docgen": "^3.0.10",
    "fumadocs-mdx": "^15.0.6",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "^16.8.11",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "oxc-transform": "^0.44.0",
    "posthog-js": "^1.219.3",
    "react": "^19.2.6",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^19.2.6",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.2",
    "react-intersection-observer": "^9.15.0",
    "react-pdf": "^9.2.1",
    "react-syntax-highlighter": "^15.6.1",
    "remark-smartypants": "^3.0.2",
    "shadcn": "^4.7.0",
    "sonner": "^1.7.2",
    "tailwind-merge": "^3.6.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
